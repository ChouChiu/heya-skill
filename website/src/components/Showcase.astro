---
export interface ExampleTag {
  type: string;
  text: string;
  variant: "accent" | "dim";
}

export interface Props {
  features: string[];
  inputText: string;
  outputTitle: string;
  examples: ExampleTag[];
}

const { features, inputText, outputTitle, examples } = Astro.props;
---

<section class="min-h-screen flex items-center max-w-[1200px] mx-auto px-4 py-6 w-full md:px-6 md:py-10">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-center w-full">
    <div>
      <h2 class="text-[32px] lg:text-[clamp(26px,3.5vw,38px)] font-extrabold leading-[1.15] tracking-[-0.03em] mb-4">
        <slot name="heading" />
      </h2>
      <p class="text-[clamp(13px,1.4vw,16px)] text-foreground-muted mb-6 leading-[1.5]">
        <slot name="subheading" />
      </p>
      <div class="flex flex-col gap-2.5">
        {features.map((feature) => (
          <div class="flex items-center gap-2.5 text-[13px] text-foreground-muted">
            <strong class="text-foreground bg-tag-bg px-2.5 py-1 rounded-md border border-border font-mono text-xs min-w-[100px] text-center">{feature}</strong>
            {feature}
          </div>
        ))}
      </div>
    </div>

    <div id="example" class="max-w-[560px] mx-auto lg:max-w-none">
      <div class="bg-surface border border-border rounded-2xl overflow-hidden shadow-[0_40px_80px_rgba(0,0,0,0.8)] transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_40px_100px_rgba(0,0,0,0.9),0_0_40px_var(--glow-accent)]">
        <div class="bg-window-bg px-5 py-3.5 border-b border-border flex items-center">
          <div class="flex gap-2">
            <i class="w-3 h-3 rounded-full bg-dot-red transition-transform duration-300 hover:scale-125"></i>
            <i class="w-3 h-3 rounded-full bg-dot-yellow transition-transform duration-300 hover:scale-125"></i>
            <i class="w-3 h-3 rounded-full bg-dot-green transition-transform duration-300 hover:scale-125"></i>
          </div>
          <div class="flex-1 text-center text-xs text-foreground-muted font-mono mr-[60px]">heya.skill - 视觉演示</div>
        </div>
        <div class="p-[18px_16px] flex flex-col gap-3.5 bg-window-bg">
          <div class="bg-surface p-6 rounded-xl border border-border relative transition-all duration-300 hover:border-border-hover">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-md absolute -top-3 left-5 bg-tag-dim-bg text-foreground-muted border border-border">原始素材</span>
            <p class="text-sm text-res-text-dim font-mono leading-[1.6] mt-1">
              {inputText}
            </p>
          </div>
          <div class="flex gap-1.5 px-5">
            <span class="circle w-2 h-2 bg-foreground-muted rounded-full animate-typing"></span>
            <span class="circle w-2 h-2 bg-foreground-muted rounded-full animate-typing"></span>
            <span class="circle w-2 h-2 bg-foreground-muted rounded-full animate-typing"></span>
          </div>
          <div class="flex flex-col gap-4 mt-2 bg-surface p-6 rounded-xl border border-border relative transition-all duration-300 hover:border-border-hover">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-md absolute -top-3 left-5 bg-accent/10 backdrop-blur-[10px] text-accent border border-accent/30">{outputTitle}</span>
            {examples.map((example) => (
              <div class="text-xs leading-[1.5] pb-2.5 border-b border-white/5 text-res-text last:border-b-0 last:pb-0">
                <span class={`inline-block text-[11px] font-semibold px-2 py-0.5 rounded mr-2 align-middle ${example.variant === "accent" ? "bg-accent/15 text-accent" : "bg-tag-dim-bg text-foreground-muted"}`}>{example.type}</span>
                {example.text}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>