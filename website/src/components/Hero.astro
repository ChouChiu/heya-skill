---
export interface Props {
  badge: string;
  title: string;
  subtitle: string;
  description: string;
  ctaPrimary: { href: string; label: string };
  ctaSecondary: { href: string; label: string };
}

const { badge, title, subtitle, description, ctaPrimary, ctaSecondary } =
  Astro.props;
---

<section class="relative min-h-screen flex flex-col items-center justify-center text-center pt-[72px] px-4 md:px-6">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] lg:w-[800px] lg:top-[5%] bg-[radial-gradient(circle,rgba(79,142,240,0.2)_0%,transparent_60%)] opacity-60 -z-1 pointer-events-none"></div>
  <div class="inline-flex items-center gap-2.5 bg-badge-bg border border-badge-border px-[18px] py-1.5 rounded-full text-[13px] font-medium text-badge-text mb-8">
    <span class="w-2 h-2 bg-live-dot rounded-full shadow-[0_0_10px_rgba(var(--shadow-glow),0.4)]"></span>
    {badge}
  </div>
  <h1 class="text-[clamp(40px,7vw,84px)] font-extrabold leading-[1.15] tracking-[-0.03em] mb-7">
    {title}<br /><span class="text-gradient">{subtitle}</span>
  </h1>
  <p class="text-[clamp(16px,2vw,20px)] text-foreground-muted max-w-[680px] mx-auto mb-14 leading-[1.7]">
    {description}
  </p>
  <div class="flex flex-col md:flex-row items-center justify-center gap-4">
    <a href={ctaPrimary.href} class="w-full md:w-auto text-center bg-foreground text-surface font-semibold px-9 py-4 rounded-full text-base transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:shadow-[0_12px_40px_var(--glow-accent)]">
      {ctaPrimary.label}
    </a>
    <a href={ctaSecondary.href} class="w-full md:w-auto text-center border border-border text-foreground font-semibold px-9 py-4 rounded-full text-base transition-all duration-300 hover:border-foreground-muted hover:bg-surface hover:-translate-y-0.5 hover:shadow-[0_8px_24px_var(--glow-accent)]">
      {ctaSecondary.label}
    </a>
  </div>
</section>