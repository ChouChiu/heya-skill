		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
	}
	.feature-card:hover::before {
		opacity: 1;
	}
	.icon-wrap {
		width: 40px;
		height: 40px;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 22px;
		margin-bottom: 14px;
		border: 1px solid rgba(255, 255, 255, 0.06);
	}
	.feature-card h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
	}
	.feature-card p {
		color: var(--text-muted);
		font-size: 13px;
		line-height: 1.5;
	}

	/* --- Split Layout / Showcase --- */
	.deep-dive {
		min-height: 100vh;
		display: flex;
		align-items: center;
	}
	.split-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 40px;
		align-items: center;
	}
	.split-text h2 {
		font-size: clamp(26px, 3.5vw, 38px);
		font-weight: 800;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}
