		border-radius: 4px;
		font-family: var(--font-mono);
	}
	.data-points {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.data-point {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 13px;
		color: var(--text-muted);
	}
	.data-point strong {
		color: var(--text-main);
		background: rgba(255, 255, 255, 0.05);
		padding: 4px 10px;
		border-radius: 6px;
		border: 1px solid var(--border);
		font-family: var(--font-mono);
		font-size: 12px;
		min-width: 100px;
		text-align: center;
	}

	.mock-window {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
